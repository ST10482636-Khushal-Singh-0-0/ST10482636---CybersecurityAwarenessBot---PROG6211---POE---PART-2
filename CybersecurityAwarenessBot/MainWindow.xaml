<Window x:Class="CybersecurityAwarenessBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mzansi's Cybersecurity Awareness Assistant" Height="600" Width="800" Background="#1E1E1E">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer x:Name="ChatScroll" Grid.Row="0" Margin="0,0,0,10" Background="#252526">
            <TextBlock x:Name="ChatOutput" Foreground="#D4D4D4" FontFamily="Consolas" FontSize="14" TextWrapping="Wrap" Padding="10"/>
        </ScrollViewer>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="UserInputBox" Grid.Column="0" Height="40" FontSize="16" Padding="5" VerticalContentAlignment="Center" KeyDown="UserInputBox_KeyDown"/>
            <Button x:Name="SendButton" Grid.Column="1" Content="Send" Width="100" Height="40" Margin="10,0,0,0" FontSize="16" Background="#FF0027FF" Foreground="White" Click="SendButton_Click" FontFamily="Arial Black"/>
        </Grid>
    </Grid>
</Window>